db.sqlite3
*.sqlite3

# Django generated files
backend/staticfiles/
backend/media/

# Environment variables
.env
.env.local

# Logs
*.log

# Node / React
node_modules/
dist/
build/
frontend/node_modules/
frontend/dist/
